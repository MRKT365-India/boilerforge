{
  "name": "@cometforge/boilerforge",
  "version": "0.1.6",
  "description": "MCP-powered boilerplate registry for AI coding agents",
  "main": "dist/mcp-server/index.js",
  "bin": {
    "boilerforge": "bin/boilerforge.js",
    "boilerforge-mcp": "dist/mcp-server/index.js"
  },
  "files": [
    "dist/",
    "boilerplates/",
    "scripts/",
    "README.md",
    "LICENSE",
    "bin/",
    "workflow-packs/"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/mcp-server/index.js dist/mcp-server/cli.js bin/boilerforge.js",
    "dev": "ts-node mcp-server/index.ts",
    "start": "node dist/mcp-server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "boilerplate",
    "ai-agent",
    "claude-code",
    "cursor",
    "scaffold",
    "starter",
    "template"
  ],
  "author": "mrkt365",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MRKT365-India/boilerforge.git"
  },
  "homepage": "https://github.com/MRKT365-India/boilerforge#readme",
  "bugs": {
    "url": "https://github.com/MRKT365-India/boilerforge/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
