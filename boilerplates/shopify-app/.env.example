# Shopify App Credentials (from Partners Dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Scopes your app needs (comma-separated)
SCOPES=write_products,read_orders,read_customers

# Your app's public URL (use ngrok or cloudflare tunnel for dev)
HOST=https://your-app.example.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/shopify_app

# Session storage (used by Shopify session management)
# Sessions are stored in the database via Prisma

# App environment
NODE_ENV=development
PORT=3000
